# ─────────────────────────────────────────────────────────────
#  IESW 2026 Registration — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

PORT=3000

# ── Google Sheets ──────────────────────────────────────────
# 1. Go to console.cloud.google.com → New Project
# 2. Enable "Google Sheets API"
# 3. Create a Service Account → generate JSON key
# 4. Share your Google Sheet with the service account email (Editor access)
# 5. Paste the values from the JSON key below

GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
SHEET_ID=your_google_sheet_id_here

# ── Gmail (for sending emails) ─────────────────────────────
# 1. Use a Gmail account (ideally a dedicated one for this event)
# 2. Enable 2-Step Verification on that Gmail account
# 3. Go to myaccount.google.com → Security → App Passwords
# 4. Create an App Password for "Mail" → paste the 16-char code below

GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ── Notification email (internal team alert) ───────────────
# Who should get an alert for every new registration?
NOTIFY_EMAIL=team@yourcompany.com
